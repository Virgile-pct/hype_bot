# Clé API Helius (gratuit sur https://helius.dev)
# Utilisée pour le RPC Solana en mode LIVE
HELIUS_API_KEY=ta_cle_helius_ici

# Clé privée de ton wallet Solana en base58
# ATTENTION : ne jamais partager cette clé, ne jamais la committer sur GitHub
# Pour l'exporter depuis Phantom : Paramètres > Gestion des comptes > Exporter la clé privée
WALLET_PRIVATE_KEY=ta_cle_privee_base58_ici
