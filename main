# ================================================================
# CONFIG
# ================================================================
@dataclass
class Config:
    # RPC & APIs
    HELIUS_API_KEY: str = os.getenv("HELIUS_API_KEY", "")
    PRIVATE_KEY: str    = os.getenv("WALLET_PRIVATE_KEY", "")

    # Capital — commence PETIT
    SNIPER_BUY_SOL: float  = 0.05    # ~5 USD par trade sniper
    HYPE_BUY_SOL: float    = 0.10    # ~10 USD par trade hype
    MAX_POSITIONS: int     = 5       # Positions simultanées max
    MAX_DAILY_SOL: float   = 1.0     # Budget journalier max

    # Filtres anti-rug (sniper)
    MIN_LIQUIDITY_USD: float       = 500.0    # Liquidité mini en USD
    MAX_DEV_WALLET_PCT: float      = 0.10     # Dev < 10% du supply
    REQUIRE_SOCIALS: bool          = False    # Exiger Twitter/site
    MAX_MCAP_SNIPER_USD: float     = 100_000  # MCap max pour sniper
    SNIPER_WINDOW_SEC: int         = 30       # Fenêtre d'achat après création

    # TP/SL sniper
    SNIPER_TP_MULT: float   = 3.0    # Vendre si x3
    SNIPER_SL_PCT: float    = 0.50   # Stop loss -50%
    SNIPER_SELL_PART: float = 0.50   # Vendre 50% au TP1
    SNIPER_TIMEOUT_MIN: int = 60     # Timeout 60min

    # Filtres hype
    HYPE_MIN_AGE_MIN: int   = 5      # Token min 5min
    HYPE_MAX_AGE_H: int     = 48     # Token max 48h (en heures)
    HYPE_MAX_AGE_MIN: int   = 20     # Token max 20min pour hype frais
    HYPE_MIN_VOL_USD: float = 10_000 # Volume 5min mini
    HYPE_PRICE_ACCEL: float = 0.30   # +30% en 5min (plus sélectif)
    HYPE_MAX_MCAP_USD: float = 5_000_000  # MCap max 5M

    # TP/SL hype
    HYPE_TP_MULT: float      = 2.0   # TP x2
    HYPE_SL_PCT: float       = 0.25  # SL -25%
    HYPE_TRAILING_PCT: float = 0.15  # Trailing 15% sous pic
    HYPE_TIMEOUT_MIN: int    = 120   # Timeout 2h

    # Swap
    SLIPPAGE_BPS: int      = 300     # 3% slippage toléré
    MIN_SOL_BALANCE: float = 0.05    # SOL minimum gardé pour les fees réseau

    # Priority fees (sniper) — 0 = auto Jupiter, sinon en micro-lamports
    # Ex: 500_000 micro-lamports ~ 0.0005 SOL de priority fee (passage rapide)
    SNIPER_PRIORITY_FEE: int = 500_000

    # WebSocket Pump.fun — détection temps réel (< 1s vs polling 5s)
    WS_ENABLED: bool = True

    # Général
    DRY_RUN: bool      = True
    LOG_FILE: str      = "sniper_hype.log"
    CSV_FILE: str      = "sniper_trades.csv"
    SCAN_INTERVAL: int = 1           # Secondes entre chaque scan (fallback HTTP)

    @property
    def HELIUS_RPC_URL(self) -> str:
        return f"https://mainnet.helius-rpc.com/?api-key={self.HELIUS_API_KEY}"


CFG = Config()


# ================================================================
# LOGGING
# ================================================================
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
    handlers=[
        logging.FileHandler(CFG.LOG_FILE, encoding="utf-8"),
        logging.StreamHandler(sys.stdout),
    ]
)
log = logging.getLogger("SOL_BOT")


def cprint(msg: str, color: str = "", bright: bool = False):
    try:
        safe_msg = msg.encode('ascii', errors='replace').decode('ascii')
        if HAS_COLOR:
            prefix = Style.BRIGHT if bright else ""
            print(f"{prefix}{color}{safe_msg}{Style.RESET_ALL}")
        else:
            print(safe_msg)
    except Exception:
        pass


# ================================================================
# WALLET MANAGER
# ================================================================
class WalletManager:
    """Gère le keypair Solana et vérifie le solde avant chaque trade."""

    def __init__(self, private_key_b58: str, rpc_url: str):
        if not HAS_SOLANA:
            raise RuntimeError(
                "Dépendances manquantes. Lance : pip install solders"
            )
        if not private_key_b58:
            raise ValueError("WALLET_PRIVATE_KEY manquant dans .env")
        try:
            self.keypair = Keypair.from_base58_string(private_key_b58)
        except Exception as e:
            raise ValueError(f"Clé privée invalide (doit être en base58) : {e}")

        self.pubkey  = str(self.keypair.pubkey())
        self.rpc_url = rpc_url
        log.info(f"Wallet chargé : {self.pubkey}")

    def get_balance_sol(self) -> float:
        try:
            payload = {
                "jsonrpc": "2.0", "id": 1,
                "method": "getBalance",
                "params": [self.pubkey]
            }
            r = requests.post(CFG.HELIUS_RPC_URL, json=payload, timeout=10)
            r.raise_for_status()
            return r.json()["result"]["value"] / 1_000_000_000
        except Exception as e:
            log.error(f"Impossible de lire le solde : {e}")
            return 0.0

    def check_balance(self, sol_needed: float) -> Tuple[bool, str]:
        balance = self.get_balance_sol()
        required = sol_needed + CFG.MIN_SOL_BALANCE
        if balance < required:
            return False, (
                f"Solde insuffisant : {balance:.4f} SOL "
                f"(besoin {required:.4f} SOL dont {CFG.MIN_SOL_BALANCE} pour les fees)"
            )
        return True, f"Solde OK : {balance:.4f} SOL"


# ================================================================
# JUPITER SWAP
# ================================================================
WSOL_MINT       = "So11111111111111111111111111111111111111112"
JUPITER_QUOTE   = "https://quote-api.jup.ag/v6/quote"
JUPITER_SWAP    = "https://quote-api.jup.ag/v6/swap"


class JupiterSwap:
    """Exécute des swaps SOL <-> token via Jupiter Aggregator."""

    def __init__(self, wallet: WalletManager):
        self.wallet  = wallet
        self.session = requests.Session()
        self.session.headers["Content-Type"] = "application/json"
        self.session.headers["User-Agent"]   = "Mozilla/5.0"

    def _get_quote(self, input_mint: str, output_mint: str, amount_lamports: int) -> Optional[dict]:
        params = {
            "inputMint":    input_mint,
            "outputMint":   output_mint,
            "amount":       amount_lamports,
            "slippageBps":  CFG.SLIPPAGE_BPS,
        }
        for attempt in range(3):
            try:
                r = self.session.get(JUPITER_QUOTE, params=params, timeout=10)
                r.raise_for_status()
                data = r.json()
                if "error" in data:
                    log.warning(f"Jupiter quote : {data['error']}")
                    return None
                return data
            except Exception as e:
                if attempt == 2:
                    log.error(f"Jupiter quote échoué après 3 tentatives : {e}")
                    return None
                time.sleep(2 ** attempt)
        return None

    def _send_swap(self, quote: dict, priority_fee: Optional[int] = None) -> Optional[Tuple[str, int]]:
        """Envoie la transaction de swap. Retourne (signature, out_amount) ou None.
        priority_fee: micro-lamports (None = auto Jupiter, 0 = auto, >0 = fixe)."""
        fee_value = "auto" if not priority_fee else priority_fee
        payload = {
            "quoteResponse":              quote,
            "userPublicKey":              self.wallet.pubkey,
            "wrapAndUnwrapSol":           True,
            "dynamicComputeUnitLimit":    True,
            "prioritizationFeeLamports":  fee_value,
        }
        for attempt in range(3):
            try:
                r = self.session.post(JUPITER_SWAP, json=payload, timeout=15)
                r.raise_for_status()
                swap_data = r.json()

                tx_bytes   = base64.b64decode(swap_data["swapTransaction"])
                tx         = VersionedTransaction.from_bytes(tx_bytes)
                signed_tx  = VersionedTransaction(tx.message, [self.wallet.keypair])

                tx_b64 = base64.b64encode(bytes(signed_tx)).decode()
                rpc_payload = {
                    "jsonrpc": "2.0", "id": 1,
                    "method": "sendTransaction",
                    "params": [tx_b64, {
                        "encoding": "base64",
                        "skipPreflight": False,
                        "preflightCommitment": "confirmed"
                    }]
                }
                rpc_r = requests.post(self.wallet.rpc_url, json=rpc_payload, timeout=30)
                rpc_r.raise_for_status()
                rpc_result = rpc_r.json()
                if "error" in rpc_result:
                    log.error(f"RPC sendTransaction error: {rpc_result['error']}")
                    return None
                sig = rpc_result["result"]

                out_amount = int(quote.get("outAmount", 0))
                log.info(f"Transaction confirmée : https://solscan.io/tx/{sig}")
                return sig, out_amount

            except Exception as e:
                if attempt == 2:
                    log.error(f"Swap échoué après 3 tentatives : {e}")
                    return None
                time.sleep(2 ** attempt)
        return None

    def buy(self, token_mint: str, sol_amount: float,
            priority_fee: Optional[int] = None) -> Optional[Tuple[str, int]]:
        """Achète token_mint avec sol_amount SOL.
        Retourne (signature_tx, token_amount_reçu) ou None si échec."""
        ok, msg = self.wallet.check_balance(sol_amount)
        if not ok:
            log.warning(f"Achat annulé — {msg}")
            return None

        lamports = int(sol_amount * 1_000_000_000)
        quote = self._get_quote(WSOL_MINT, token_mint, lamports)
        if not quote:
            return None

        result = self._send_swap(quote, priority_fee=priority_fee)
        if result:
            sig, out_amount = result
            cprint(f"   Achat OK : {out_amount} tokens | tx: {sig[:16]}...", Fore.GREEN)
        return result

    def sell(self, token_mint: str, token_amount: int) -> Optional[str]:
        """Vend token_amount (unités brutes) contre SOL.
        Retourne la signature ou None si échec."""
        if token_amount <= 0:
            log.warning("sell() appelé avec token_amount <= 0, ignoré")
            return None

        quote = self._get_quote(token_mint, WSOL_MINT, token_amount)
        if not quote:
            return None

        result = self._send_swap(quote)
        if result:
            sig, sol_received = result
            cprint(f"   Vente OK : {sol_received / 1e9:.4f} SOL récupérés | tx: {sig[:16]}...", Fore.GREEN)
            return sig
        return None


# ================================================================
# DEXSCREENER API (gratuit, pas de clé)
# ================================================================
class DexScreener:
    BASE = "https://api.dexscreener.com/latest/dex"

    def __init__(self):
        self.session = requests.Session()
        self.session.headers["User-Agent"] = "Mozilla/5.0"

    def _get(self, url: str) -> dict:
        for attempt in range(3):
            try:
                r = self.session.get(url, timeout=10)
                r.raise_for_status()
                return r.json()
            except Exception as e:
                if attempt == 2:
                    log.debug(f"DexScreener: {e}")
                    return {}
                time.sleep(2 ** attempt)
        return {}

    def get_pairs_by_token(self, mint: str) -> list:
        data = self._get(f"{self.BASE}/tokens/{mint}")
        return data.get("pairs", [])

    def get_new_pairs_solana(self) -> list:
        data = self._get(f"{self.BASE}/pairs/solana")
        return data.get("pairs", [])

    def get_boosted_tokens(self) -> list:
        for attempt in range(3):
            try:
                r = self.session.get(
                    "https://api.dexscreener.com/token-boosts/latest/v1", timeout=10
                )
                r.raise_for_status()
                data = r.json()
                return data if isinstance(data, list) else []
            except Exception as e:
                if attempt == 2:
                    log.debug(f"DexScreener boosts: {e}")
                    return []
                time.sleep(2 ** attempt)
        return []


# ================================================================
# PUMP.FUN API (gratuit)
# ================================================================
class PumpFunAPI:
    BASE = "https://frontend-api.pump.fun"

    def __init__(self):
        self.session = requests.Session()
        self.session.headers["User-Agent"] = "Mozilla/5.0"

    def get_latest_tokens(self, limit: int = 50) -> list:
        for attempt in range(3):
            try:
                r = self.session.get(
                    f"{self.BASE}/coins/latest",
                    params={"limit": limit, "includeNsfw": False},
                    timeout=10
                )
                r.raise_for_status()
                data = r.json()
                return data if isinstance(data, list) else []
            except Exception as e:
                if attempt == 2:
                    log.debug(f"PumpFun: {e}")
                    return []
                time.sleep(2 ** attempt)
        return []

    def get_king_of_hill(self) -> list:
        """Tokens proches de graduation vers Raydium."""
        try:
            r = self.session.get(
                f"{self.BASE}/coins",
                params={"limit": 20, "sort": "market_cap",
                        "order": "DESC", "includeNsfw": False},
                timeout=10
            )
            data = r.json()
            return data if isinstance(data, list) else []
        except:
            return []


# ================================================================
# PUMP.FUN WEBSOCKET — détection temps réel des nouveaux tokens
# ================================================================
class PumpFunWebSocket:
    """Connexion WebSocket temps réel via pumpportal.fun.
    Remplace le polling HTTP : latence < 1s vs 5s.
    Fallback automatique vers HTTP polling si indisponible."""

    WS_URL = "wss://pumpportal.fun/api/data"

    def __init__(self):
        self._queue: asyncio.Queue = asyncio.Queue(maxsize=500)
        self._ws = None
        self._connected = False
        self._task: Optional[asyncio.Task] = None

    async def start(self):
        """Démarre la connexion WebSocket en tâche de fond. Non-bloquant."""
        try:
            import websockets  # type: ignore
            self._task = asyncio.create_task(self._run(websockets))
            # Laisser la tâche démarrer
            await asyncio.sleep(0.5)
        except ImportError:
            log.warning("websockets absent — fallback HTTP polling (pip install websockets)")
        except Exception as e:
            log.warning(f"PumpFun WebSocket indisponible : {e} — fallback HTTP polling")

    async def _run(self, websockets_module):
        """Boucle de connexion avec reconnexion automatique."""
        delay = 2
        while True:
            try:
                async with websockets_module.connect(
                    self.WS_URL,
                    ping_interval=20,
                    ping_timeout=10,
                    open_timeout=10,
                ) as ws:
                    self._ws = ws
                    self._connected = True
                    delay = 2  # reset backoff
                    log.info("PumpPortal WebSocket connecte — sniper en temps reel")

                    # S'abonner aux nouveaux tokens
                    import json
                    await ws.send(json.dumps({"method": "subscribeNewToken"}))

                    async for message in ws:
                        try:
                            data = json.loads(message)
                            # Normaliser le format pumpportal → format attendu par SniperBot
                            token = self._normalize(data)
                            if token:
                                try:
                                    self._queue.put_nowait(token)
                                except asyncio.QueueFull:
                                    pass
                        except Exception:
                            pass

            except Exception as e:
                self._connected = False
                self._ws = None
                log.warning(f"PumpPortal WebSocket deconnecte : {e} — reconnexion dans {delay}s")
                await asyncio.sleep(delay)
                delay = min(delay * 2, 60)

    @staticmethod
    def _normalize(data: dict) -> Optional[dict]:
        """Convertit un event pumpportal au format attendu par SniperBot."""
        mint = data.get("mint")
        if not mint:
            return None
        return {
            "mint":               mint,
            "name":               data.get("name", ""),
            "symbol":             data.get("symbol", ""),
            "created_timestamp":  data.get("timestamp", time.time() * 1000),
            "twitter":            data.get("twitter", ""),
            "website":            data.get("website", ""),
            "bonding_curve_progress": data.get("vSolInBondingCurve", 0),
            "dev_sold":           False,
        }

    async def stop(self):
        if self._task:
            self._task.cancel()
        if self._ws:
            await self._ws.close()

    @property
    def is_live(self) -> bool:
        return self._connected

    def drain(self) -> list:
        """Retourne tous les tokens en attente (non-bloquant)."""
        tokens = []
        while True:
            try:
                tokens.append(self._queue.get_nowait())
            except asyncio.QueueEmpty:
                break
        return tokens


# ================================================================
# FILTRES ANTI-RUG
# ================================================================
class RugFilter:
    def check_pumpfun(self, token: dict) -> Tuple[bool, str]:
        """Vérifie un token Pump.fun. Retourne (ok, raison)."""
        if token.get("dev_sold"):
            return False, "Dev a vendu"

        if CFG.REQUIRE_SOCIALS:
            if not token.get("twitter") and not token.get("website"):
                return False, "Pas de socials"

        bonding_pct = float(token.get("bonding_curve_progress", 0))
        if bonding_pct > 95:
            return False, "Bonding curve > 95% (trop tard)"

        return True, ""

    def check_pair(self, pair: dict, mode: str = "SNIPER") -> Tuple[bool, str]:
        """Vérifie une paire DexScreener."""
        if pair.get("chainId") != "solana":
            return False, "Pas Solana"

        liq = float((pair.get("liquidity") or {}).get("usd") or 0)
        if liq < CFG.MIN_LIQUIDITY_USD:
            return False, f"Liquidité ${liq:.0f} < ${CFG.MIN_LIQUIDITY_USD}"

        mcap = float(pair.get("marketCap") or 0)
        max_mcap = CFG.MAX_MCAP_SNIPER_USD if mode == "SNIPER" else CFG.HYPE_MAX_MCAP_USD
        if mcap > max_mcap:
            return False, f"MCap ${mcap:,.0f} > ${max_mcap:,.0f}"

        txns = (pair.get("txns") or {}).get("m5") or {}
        buys  = int(txns.get("buys") or 0)
        sells = int(txns.get("sells") or 0)
        if buys + sells > 0 and sells > buys * 2:
            return False, f"Dump en cours ({buys}B/{sells}S)"
        if mode == "HYPE" and buys < 10:
            return False, f"Pas assez d'acheteurs: {buys}"

        return True, ""


# ================================================================
# POSITION MANAGER
# ================================================================
@dataclass
class Position:
    mint: str
    symbol: str
    name: str
    entry_price: float
    entry_time: float
    sol_invested: float
    strategy: str
    peak_price: float = 0.0
    partial_sold: bool = False
    status: str = "OPEN"
    exit_price: float = 0.0
    exit_reason: str = ""
    pnl_sol: float = 0.0
    # Mode LIVE : suivi des tokens détenus
    token_amount: int = 0      # Quantité brute de tokens achetés
    tx_sig_buy: str   = ""     # Signature transaction d'achat


class PositionManager:
    def __init__(self):
        self.positions: dict = {}
        self.closed: list    = []
        self.daily_sol       = 0.0
        self.day             = datetime.now().date()

    def _reset_daily(self):
        today = datetime.now().date()
        if today != self.day:
            self.daily_sol = 0.0
            self.day = today

    def can_open(self, sol: float) -> Tuple[bool, str]:
        self._reset_daily()
        if len(self.positions) >= CFG.MAX_POSITIONS:
            return False, f"Max {CFG.MAX_POSITIONS} positions atteint"
        if self.daily_sol + sol > CFG.MAX_DAILY_SOL:
            return False, f"Budget journalier {self.daily_sol:.3f}/{CFG.MAX_DAILY_SOL} SOL"
        return True, ""

    def open(self, pos: Position):
        self.positions[pos.mint] = pos
        self.daily_sol += pos.sol_invested
        self._log_csv("OPEN", pos)

    def close(self, mint: str, price: float, reason: str) -> Optional[Position]:
        pos = self.positions.pop(mint, None)
        if not pos:
            return None
        pos.status      = "CLOSED"
        pos.exit_price  = price
        pos.exit_reason = reason
        mult = price / pos.entry_price if pos.entry_price else 0
        pos.pnl_sol     = pos.sol_invested * (mult - 1)
        self.closed.append(pos)
        self._log_csv("CLOSE", pos)
        return pos

    def _log_csv(self, action: str, pos: Position):
        row = {
            "datetime":    datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            "action":      action,
            "strategy":    pos.strategy,
            "mint":        pos.mint,
            "symbol":      pos.symbol,
            "entry_price": pos.entry_price,
            "exit_price":  pos.exit_price,
            "sol_invested": pos.sol_invested,
            "pnl_sol":     pos.pnl_sol,
            "exit_reason": pos.exit_reason,
            "dry_run":     CFG.DRY_RUN,
            "tx_buy":      pos.tx_sig_buy,
        }
        exists = os.path.exists(CFG.CSV_FILE)
        with open(CFG.CSV_FILE, "a", newline="", encoding="utf-8") as f:
            w = csv.DictWriter(f, fieldnames=row.keys())
            if not exists:
                w.writeheader()
            w.writerow(row)

    def summary(self) -> str:
        total_pnl = sum(p.pnl_sol for p in self.closed)
        wins  = sum(1 for p in self.closed if p.pnl_sol > 0)
        total = len(self.closed)
        wr    = wins / total * 100 if total else 0
        return (
            f"Trades: {total} | WR: {wr:.0f}% | "
            f"PnL: {total_pnl:+.4f} SOL | "
            f"Open: {len(self.positions)}"
        )


# ================================================================
# MODULE 1 — SNIPER
# ================================================================
class SniperBot:
    def __init__(self, pm: PositionManager, dex: DexScreener,
                 pump: PumpFunAPI, rug: RugFilter,
                 jupiter: Optional[JupiterSwap] = None,
                 ws: Optional["PumpFunWebSocket"] = None):
        self.pm      = pm
        self.dex     = dex
        self.pump    = pump
        self.rug     = rug
        self.jupiter = jupiter
        self.ws      = ws
        self.seen: set = set()

    async def scan(self):
        # WebSocket temps réel si dispo, sinon fallback HTTP polling
        if self.ws and self.ws.is_live:
            tokens = self.ws.drain()
        else:
            tokens = self.pump.get_latest_tokens(50)

        now = time.time()
        candidates = []

        for token in tokens:
            mint = token.get("mint", "")
            if not mint or mint in self.seen:
                continue

            created = (token.get("created_timestamp") or 0) / 1000
            age_sec = now - created

            if age_sec > CFG.SNIPER_WINDOW_SEC:
                self.seen.add(mint)
                continue

            ok, _ = self.rug.check_pumpfun(token)
            if not ok:
                self.seen.add(mint)
                continue

            candidates.append((mint, token, age_sec))

        if not candidates:
            return

        # Vérification DexScreener en parallèle pour tous les candidats
        async def check_candidate(mint, token, age_sec):
            pairs = self.dex.get_pairs_by_token(mint)
            self.seen.add(mint)
            if not pairs:
                return
            pair = pairs[0]
            ok2, _ = self.rug.check_pair(pair, "SNIPER")
            if not ok2:
                return
            can, _ = self.pm.can_open(CFG.SNIPER_BUY_SOL)
            if not can:
                return
            price  = float(pair.get("priceNative") or 0)
            symbol = (pair.get("baseToken") or {}).get("symbol", "???")
            name   = (pair.get("baseToken") or {}).get("name", "???")
            mcap   = float(pair.get("marketCap") or 0)
            await self._buy(mint, symbol, name, price, mcap, age_sec)

        await asyncio.gather(
            *(check_candidate(m, t, a) for m, t, a in candidates),
            return_exceptions=True
        )

    async def _buy(self, mint, symbol, name, price, mcap, age_sec):
        label = "DRY RUN" if CFG.DRY_RUN else "LIVE"
        cprint(f"\n[SNIPER {label}] {symbol} ({name})", Fore.CYAN, bright=True)
        cprint(f"   Age: {age_sec:.0f}s | MCap: ${mcap:,.0f} | Prix: {price:.10f} SOL", Fore.CYAN)
        cprint(f"   TP: x{CFG.SNIPER_TP_MULT} | SL: -{CFG.SNIPER_SL_PCT*100:.0f}% | {CFG.SNIPER_BUY_SOL} SOL investi", Fore.CYAN)

        token_amount = 0
        tx_sig       = ""

        if not CFG.DRY_RUN:
            # Priority fee élevé pour le sniper = passe avant les autres bots
            result = self.jupiter.buy(mint, CFG.SNIPER_BUY_SOL,
                                      priority_fee=CFG.SNIPER_PRIORITY_FEE)
            if not result:
                cprint(f"   Achat ECHOUE pour {symbol}, on passe.", Fore.RED)
                return
            tx_sig, token_amount = result

        pos = Position(
            mint=mint, symbol=symbol, name=name,
            entry_price=price, entry_time=time.time(),
            sol_invested=CFG.SNIPER_BUY_SOL,
            strategy="SNIPER", peak_price=price,
            token_amount=token_amount,
            tx_sig_buy=tx_sig,
        )
        self.pm.open(pos)

    async def monitor(self):
        sniper_pos = {k: v for k, v in self.pm.positions.items()
                      if v.strategy == "SNIPER"}
        if not sniper_pos:
            return

        async def _check(mint, pos):
            pairs = self.dex.get_pairs_by_token(mint)
            if not pairs:
                return

            price   = float(pairs[0].get("priceNative") or pos.entry_price)
            mult    = price / pos.entry_price if pos.entry_price else 0
            dur_min = (time.time() - pos.entry_time) / 60

            pos.peak_price = max(pos.peak_price, price)
            reason = None

            # TP partiel (vend 50% au premier TP)
            if not pos.partial_sold and mult >= CFG.SNIPER_TP_MULT:
                pos.partial_sold = True
                cprint(f"  [SNIPER] {pos.symbol} TP1 x{mult:.1f} — vente partielle 50%", Fore.GREEN)
                if not CFG.DRY_RUN and self.jupiter and pos.token_amount > 0:
                    sell_amount = pos.token_amount // 2
                    self.jupiter.sell(mint, sell_amount)
                    pos.token_amount -= sell_amount

            # Trailing stop après TP1
            if pos.partial_sold:
                trail = pos.peak_price * 0.75
                if price <= trail:
                    reason = f"TRAILING (pic x{pos.peak_price/pos.entry_price:.1f})"

            if mult <= (1 - CFG.SNIPER_SL_PCT):
                reason = f"SL -{CFG.SNIPER_SL_PCT*100:.0f}%"

            if dur_min >= CFG.SNIPER_TIMEOUT_MIN:
                reason = f"TIMEOUT {dur_min:.0f}min"

            if reason:
                if not CFG.DRY_RUN and self.jupiter and pos.token_amount > 0:
                    self.jupiter.sell(mint, pos.token_amount)
                closed = self.pm.close(mint, price, reason)
                if closed:
                    ok = closed.pnl_sol > 0
                    emoji = "OK" if ok else "XX"
                    color = Fore.GREEN if ok else Fore.RED
                    cprint(
                        f"  [{emoji}][SNIPER] {pos.symbol} — {reason} | "
                        f"x{mult:.2f} | PnL: {closed.pnl_sol:+.4f} SOL",
                        color, bright=True
                    )

        await asyncio.gather(
            *(_check(m, p) for m, p in list(sniper_pos.items())),
            return_exceptions=True
        )


# ================================================================
# MODULE 2 — HYPE DETECTOR
# ================================================================
class HypeBot:
    def __init__(self, pm: PositionManager, dex: DexScreener,
                 rug: RugFilter, jupiter: Optional[JupiterSwap] = None):
        self.pm          = pm
        self.dex         = dex
        self.rug         = rug
        self.jupiter     = jupiter
        self.seen_today: set = set()

    async def scan(self):
        sources = [
            (self.dex.get_boosted_tokens(), "BOOST"),
            (self.dex.get_new_pairs_solana(), "NEW"),
        ]
        for tokens, source in sources:
            await self._analyze(tokens, source)

    @staticmethod
    def _score(pair: dict, age_min: float) -> float:
        """Score de qualité du signal hype (plus haut = meilleur).
        Combine momentum prix, volume et timing optimal."""
        change5m = float((pair.get("priceChange") or {}).get("m5") or 0)
        change1h = float((pair.get("priceChange") or {}).get("h1") or 0)
        vol5m    = float((pair.get("volume") or {}).get("m5") or 0)
        txns     = (pair.get("txns") or {}).get("m5") or {}
        buys     = int(txns.get("buys") or 0)
        sells    = int(txns.get("sells") or 0)
        liq      = float((pair.get("liquidity") or {}).get("usd") or 0)
        mcap     = float(pair.get("marketCap") or 1)

        # Momentum pondéré (5min compte plus que 1h)
        momentum = change5m * 0.7 + max(change1h, 0) * 0.3

        # Ratio acheteurs/vendeurs (0.5 à 2)
        buy_ratio = buys / max(buys + sells, 1)
        ratio_score = min(buy_ratio * 2, 2.0)

        # Fenêtre d'âge optimale : 7-12 min = score max
        if 7 <= age_min <= 12:
            age_score = 1.0
        elif age_min < 7:
            age_score = age_min / 7
        else:
            age_score = max(0, 1 - (age_min - 12) / 8)

        # Volume normalisé (log scale)
        import math
        vol_score = math.log10(max(vol5m, 1)) / math.log10(100_000)

        return momentum * ratio_score * age_score * vol_score

    async def _analyze(self, items: list, source: str):
        now = time.time()
        scored_candidates = []

        for item in items:
            mint = (item.get("tokenAddress") or
                    (item.get("baseToken") or {}).get("address", ""))
            if not mint or mint in self.pm.positions or mint in self.seen_today:
                continue

            pairs = self.dex.get_pairs_by_token(mint)
            if not pairs:
                continue

            pairs = sorted(
                pairs,
                key=lambda p: float((p.get("volume") or {}).get("h24") or 0),
                reverse=True
            )
            pair = pairs[0]

            created = (pair.get("pairCreatedAt") or 0) / 1000
            age_min = (now - created) / 60
            age_h   = age_min / 60

            if age_min < CFG.HYPE_MIN_AGE_MIN:
                continue
            if age_min > CFG.HYPE_MAX_AGE_MIN:
                continue
            if age_h > CFG.HYPE_MAX_AGE_H:
                continue

            vol5m = float((pair.get("volume") or {}).get("m5") or 0)
            if vol5m < CFG.HYPE_MIN_VOL_USD:
                continue

            change5m = float((pair.get("priceChange") or {}).get("m5") or 0)
            if change5m < CFG.HYPE_PRICE_ACCEL * 100:
                continue

            ok, _ = self.rug.check_pair(pair, "HYPE")
            if not ok:
                continue

            score = self._score(pair, age_min)
            scored_candidates.append((score, mint, pair, age_min, change5m, vol5m))

        if not scored_candidates:
            return

        # Ne prend que le meilleur signal du cycle (évite le FOMO sur tout)
        scored_candidates.sort(key=lambda x: x[0], reverse=True)
        best = scored_candidates[0]
        _, mint, pair, age_min, change5m, vol5m = best

        can, _ = self.pm.can_open(CFG.HYPE_BUY_SOL)
        if not can:
            return

        price  = float(pair.get("priceNative") or 0)
        symbol = (pair.get("baseToken") or {}).get("symbol", "???")
        name   = (pair.get("baseToken") or {}).get("name", "???")
        mcap   = float(pair.get("marketCap") or 0)

        await self._buy(mint, symbol, name, price, age_min, change5m, vol5m, mcap, source)
        self.seen_today.add(mint)
        # Marquer aussi les autres candidats pour éviter de les reprendre
        for _, m, _, _, _, _ in scored_candidates[1:]:
            self.seen_today.add(m)

    async def _buy(self, mint, symbol, name, price, age_min, change5m, vol5m, mcap, source):
        label = "DRY RUN" if CFG.DRY_RUN else "LIVE"
        cprint(f"\n[HYPE {label}] {symbol} ({name}) [{source}]", Fore.MAGENTA, bright=True)
        cprint(f"   Age: {age_min:.0f}min | +{change5m:.1f}% en 5min | Vol5m: ${vol5m:,.0f}", Fore.MAGENTA)
        cprint(f"   MCap: ${mcap:,.0f} | TP: x{CFG.HYPE_TP_MULT} | SL: -{CFG.HYPE_SL_PCT*100:.0f}%", Fore.MAGENTA)

        token_amount = 0
        tx_sig       = ""

        if not CFG.DRY_RUN:
            result = self.jupiter.buy(mint, CFG.HYPE_BUY_SOL)
            if not result:
                cprint(f"   Achat ECHOUE pour {symbol}, on passe.", Fore.RED)
                return
            tx_sig, token_amount = result

        pos = Position(
            mint=mint, symbol=symbol, name=name,
            entry_price=price, entry_time=time.time(),
            sol_invested=CFG.HYPE_BUY_SOL,
            strategy="HYPE", peak_price=price,
            token_amount=token_amount,
            tx_sig_buy=tx_sig,
        )
        self.pm.open(pos)

    async def monitor(self):
        hype_pos = {k: v for k, v in self.pm.positions.items()
                    if v.strategy == "HYPE"}
        if not hype_pos:
            return

        async def _check(mint, pos):
            pairs = self.dex.get_pairs_by_token(mint)
            if not pairs:
                return

            price   = float(pairs[0].get("priceNative") or pos.entry_price)
            mult    = price / pos.entry_price if pos.entry_price else 0
            dur_min = (time.time() - pos.entry_time) / 60

            pos.peak_price = max(pos.peak_price, price)
            reason = None

            if mult >= CFG.HYPE_TP_MULT:
                reason = f"TP x{mult:.1f}"

            if mult >= 1.10:
                trail = pos.peak_price * (1 - CFG.HYPE_TRAILING_PCT)
                if price <= trail:
                    reason = f"TRAILING (pic x{pos.peak_price/pos.entry_price:.1f})"

            if mult <= (1 - CFG.HYPE_SL_PCT):
                reason = f"SL -{CFG.HYPE_SL_PCT*100:.0f}%"

            if dur_min >= CFG.HYPE_TIMEOUT_MIN:
                reason = f"TIMEOUT {dur_min:.0f}min"

            if reason:
                if not CFG.DRY_RUN and self.jupiter and pos.token_amount > 0:
                    self.jupiter.sell(mint, pos.token_amount)
                closed = self.pm.close(mint, price, reason)
                if closed:
                    ok = closed.pnl_sol > 0
                    emoji = "OK" if ok else "XX"
                    color = Fore.GREEN if ok else Fore.RED
                    cprint(
                        f"  [{emoji}][HYPE] {pos.symbol} — {reason} | "
                        f"x{mult:.2f} | PnL: {closed.pnl_sol:+.4f} SOL",
                        color, bright=True
                    )

        await asyncio.gather(
            *(_check(m, p) for m, p in list(hype_pos.items())),
            return_exceptions=True
        )


# ================================================================
# BOUCLE PRINCIPALE
# ================================================================
async def main_loop(jupiter: Optional[JupiterSwap] = None):
    dex  = DexScreener()
    pump = PumpFunAPI()
    rug  = RugFilter()
    pm   = PositionManager()

    # WebSocket Pump.fun temps réel
    ws = None
    if CFG.WS_ENABLED:
        ws = PumpFunWebSocket()
        await ws.start()

    sniper = SniperBot(pm, dex, pump, rug, jupiter, ws=ws)
    hype   = HypeBot(pm, dex, rug, jupiter)

    mode = "DRY RUN" if CFG.DRY_RUN else "LIVE"
    cprint("=" * 60, Fore.WHITE, bright=True)
    cprint(f"  SOLANA SNIPER + HYPE BOT — {mode}", Fore.CYAN, bright=True)
    cprint(f"  Sniper : {CFG.SNIPER_BUY_SOL} SOL | TP x{CFG.SNIPER_TP_MULT} | SL -{CFG.SNIPER_SL_PCT*100:.0f}%", Fore.WHITE)
    cprint(f"  Hype   : {CFG.HYPE_BUY_SOL} SOL | TP x{CFG.HYPE_TP_MULT} | SL -{CFG.HYPE_SL_PCT*100:.0f}%", Fore.WHITE)
    cprint(f"  Budget max/jour : {CFG.MAX_DAILY_SOL} SOL", Fore.WHITE)
    if ws:
        ws_status = "WebSocket temps reel" if ws.is_live else "HTTP polling (fallback)"
        cprint(f"  Sniper source : {ws_status}", Fore.CYAN)
    if not CFG.DRY_RUN and jupiter:
        bal = jupiter.wallet.get_balance_sol()
        cprint(f"  Wallet : {jupiter.wallet.pubkey[:16]}... | Solde : {bal:.4f} SOL", Fore.YELLOW)
    cprint("=" * 60, Fore.WHITE, bright=True)

    cycle = 0
    try:
        while True:
            cycle += 1
            try:
                # Scan et monitor en parallèle pour réduire la latence totale
                await asyncio.gather(
                    sniper.scan(),
                    hype.scan(),
                    sniper.monitor(),
                    hype.monitor(),
                    return_exceptions=True,
                )

                if cycle % 12 == 0:
                    ws_tag = "[WS]" if (ws and ws.is_live) else "[HTTP]"
                    cprint(f"  [{datetime.now().strftime('%H:%M:%S')}] {ws_tag} {pm.summary()}", Fore.WHITE)

            except KeyboardInterrupt:
                break
            except Exception as e:
                log.error(f"Erreur: {e}", exc_info=True)

            await asyncio.sleep(CFG.SCAN_INTERVAL)
    finally:
        if ws:
            await ws.stop()

    cprint(f"\n  Arrêt — {pm.summary()}", Fore.WHITE, bright=True)


# ================================================================
# MAIN
# ================================================================
def main():
    parser = argparse.ArgumentParser(description="Solana Sniper + Hype Bot")
    parser.add_argument("--live",              action="store_true", help="Vrais achats")
    parser.add_argument("--sniper-sol",        type=float,          help="SOL par trade sniper")
    parser.add_argument("--hype-sol",          type=float,          help="SOL par trade hype")
    parser.add_argument("--max-daily",         type=float,          help="Budget journalier max SOL")
    parser.add_argument("--slippage-bps",      type=int,            help="Slippage en bps (défaut: 300 = 3%%)")
    parser.add_argument("--priority-fee",      type=int,            help="Priority fee sniper en micro-lamports (défaut: 500000)")
    parser.add_argument("--no-websocket",      action="store_true", help="Désactiver WebSocket, utiliser HTTP polling")
    parser.add_argument("--require-socials",   action="store_true")
    args = parser.parse_args()

    if args.sniper_sol:      CFG.SNIPER_BUY_SOL      = args.sniper_sol
    if args.hype_sol:        CFG.HYPE_BUY_SOL         = args.hype_sol
    if args.max_daily:       CFG.MAX_DAILY_SOL         = args.max_daily
    if args.slippage_bps:    CFG.SLIPPAGE_BPS          = args.slippage_bps
    if args.priority_fee:    CFG.SNIPER_PRIORITY_FEE   = args.priority_fee
    if args.no_websocket:    CFG.WS_ENABLED            = False
    if args.require_socials: CFG.REQUIRE_SOCIALS        = True

    jupiter = None

    if args.live:
        if not CFG.HELIUS_API_KEY:
            print("HELIUS_API_KEY manquant dans .env (nécessaire pour le mode LIVE)")
            sys.exit(1)
        if not HAS_SOLANA:
            print("Dépendances manquantes. Lance : pip install solders solana")
            sys.exit(1)

        confirm = input("Mode LIVE — vrais SOL depenses. Confirmer ? (oui/non) : ")
        if confirm.strip().lower() != "oui":
            sys.exit(0)

        try:
            wallet  = WalletManager(CFG.PRIVATE_KEY, CFG.HELIUS_RPC_URL)
            jupiter = JupiterSwap(wallet)
        except (ValueError, RuntimeError) as e:
            print(f"Erreur wallet : {e}")
            sys.exit(1)

        CFG.DRY_RUN = False

    asyncio.run(main_loop(jupiter))


if __name__ == "__main__":
    main()
